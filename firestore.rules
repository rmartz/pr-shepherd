rules_version = '2';

// Security model
// --------------
// PR Shepherd writes all daemon state via the firebase-admin SDK, which
// bypasses these rules entirely. Client SDK access (the read-only Next.js UI
// for monitoring run state) is constrained here: authenticated reads on the
// three daemon collections, no client writes ever.
//
// - Daemon writes:     admin SDK (rules do not apply)
// - UI reads:          require auth, scoped to the three daemon collections
// - UI writes:         denied (UI is read-only by design)
// - Any other path:    deny-all default
//
// The auth requirement on reads exists so the deployed UI can gate access
// behind whatever auth provider it integrates with (Vercel password
// protection, OAuth, etc.). Local-only operators using the UI against the
// emulator can run unauthenticated by setting auth bypass in the emulator
// config — the rules themselves enforce auth in production.

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny — no access unless explicitly granted below.
    match /{document=**} {
      allow read, write: if false;
    }

    // Daemon state collections — authenticated read; writes always denied
    // (admin SDK bypasses these rules and is the only writer).
    match /repositories/{repoId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /workflowRuns/{runId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /stepInstances/{stepId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
