rules_version = '2';

// Security model
// --------------
// PR Shepherd writes all daemon state via the firebase-admin SDK, which
// bypasses these rules entirely. Client SDK access (the read-only Next.js UI
// for monitoring run state) is constrained here: authenticated reads on the
// three daemon collections, no client writes ever.
//
// - Daemon writes:     admin SDK (rules do not apply)
// - UI reads:          require auth + email allowlist (see isAllowedOperator)
// - UI writes:         denied (UI is read-only by design)
// - Any other path:    deny-all default
//
// The auth requirement on reads exists so the deployed UI gates access
// behind Firebase Authentication. Firestore rules evaluate `request.auth`
// exclusively from Firebase Auth tokens — edge-level mechanisms such as
// Vercel password protection do not populate this field and cannot satisfy
// the rule. Local operators using the UI against the emulator can bypass
// auth by configuring the Auth emulator accordingly.
//
// Operator allowlist
// ------------------
// `isAllowedOperator()` restricts read access to a hardcoded list of
// email addresses. To grant a new operator access:
//
//   1. Add the email to the inline `email in [...]` list inside
//      `isAllowedOperator()` below (lowercase, exact match).
//   2. Re-deploy these rules: `firebase deploy --only firestore:rules`.
//   3. The new operator can sign in via the UI's /sign-in page using their
//      Google account associated with that email.
//
// The list is intentionally tiny and version-controlled. Larger or more
// dynamic allowlists (Firestore-backed, custom claims, etc.) are out of
// scope for v1 — see vision #1 §15.

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny — no access unless explicitly granted below.
    match /{document=**} {
      allow read, write: if false;
    }

    // Daemon state collections — authenticated allowlisted-operator read;
    // writes always denied (admin SDK bypasses these rules and is the only writer).
    match /repositories/{repoId} {
      allow read: if isAllowedOperator();
      allow write: if false;
    }

    match /workflowRuns/{runId} {
      allow read: if isAllowedOperator();
      allow write: if false;
    }

    match /stepInstances/{stepId} {
      allow read: if isAllowedOperator();
      allow write: if false;
    }

    function isAllowedOperator() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in [
          // Edit this list to grant operator access. Each entry must be a
          // lowercase, exact-match email associated with the operator's
          // Firebase Auth account (typically via Google sign-in).
          'operator@example.com'
        ];
    }
  }
}
