#!/usr/bin/env bash
# Committed pre-commit hook that git runs in EVERY worktree (via core.hooksPath),
# whose one remaining job is to dispatch to husky's .husky/pre-commit in the
# primary checkout. Without it, pointing core.hooksPath at claude/hooks would
# redirect the primary checkout away from husky entirely (see #185).
#
# Activated by pointing the repo at this directory:
#
#   core.hooksPath = claude/hooks
#
# new-worktree.py's configure_claude_hooks() sets that automatically whenever a
# repo ships claude/hooks/pre-commit — its present-file detection keys on this
# exact path. core.hooksPath lives in the shared (common) git config, so a
# single set applies to the primary checkout and every linked worktree; the
# relative path resolves against each worktree's own root.
#
# The file-length hard cap is now the ESLint `max-lines` rule, enforced by
# `pnpm lint` (pre-push-verify and CI) and, for the primary checkout, by
# lint-staged. There is no separate length check here, so this hook stays
# zero-dependency (node only, no node_modules) and just hands
# off to husky in the primary checkout.
#
# Husky coexistence (#185): core.hooksPath is repo-wide, so pointing it here
# redirects EVERY worktree — including the primary checkout — away from husky's
# .husky/ hooks. To keep husky's checks (lint-staged, conflict-markers,
# validate-config) firing for human commits in the primary worktree, this hook
# dispatches to .husky/pre-commit there. A linked worktree's `.git` is a FILE (a
# gitdir pointer); the primary checkout's `.git` is a DIRECTORY — that
# distinction is how we tell them apart, so husky never runs in an agent
# worktree.
#
# Bypass: `git commit --no-verify` skips the hook (git-native).
set -e

# Primary-worktree only: hand off to husky if this repo also uses it. `.git` is
# a directory in the primary checkout and a file in a linked worktree.
if [ -d .git ] && [ -x .husky/pre-commit ]; then
  ./.husky/pre-commit
fi
