# Root-only guard (#185): these checks run only for manual commits in the
# primary checkout. A linked worktree's `.git` is a FILE (a gitdir pointer); the
# primary checkout's `.git` is a DIRECTORY. Skip in any linked worktree —
# node_modules (needed by lint-staged) may be absent there; agent worktrees
# exit early and receive no pre-commit checks (claude/hooks/pre-commit only
# dispatches here for the primary checkout). The file-length cap that used to
# run there is now the ESLint max-lines rule, enforced at push time by
# pre-push-verify and in CI.
if [ -f .git ]; then
  exit 0
fi
# Block staged merge-conflict markers first — before lint-staged's prettier can
# reflow and corrupt them. `--no-verify` or ALLOW_CONFLICT_MARKERS=1 bypasses.
node scripts/check-conflict-markers.mjs --staged
pnpm exec lint-staged
# Local deployment-config validation (a repo-local script) still runs at commit.
# Its schema hard-denies `*SECRET*` / `*_TOKEN*` / `*PRIVATE_KEY*` keys, so it
# doubles as the guard against secrets landing in the public `deployment/*.yml`.
# The same check runs in CI via `.github/workflows/validate-config.yml`.
node scripts/validate-config.mjs
# The file-length hard cap is now the ESLint `max-lines` rule: enforced here for
# the primary checkout via lint-staged (eslint on staged files), and in CI +
# pre-push-verify via `pnpm lint`. There is no separate length check.
#
# There is no repo-wide secret scan: broader env-config tooling (secret rotation,
# `.env.local` sync) is being consolidated into the standalone `envctl` tool
# (usage TBD). Until it lands, the deployment-config schema check above is the
# secret guard for the config files.
